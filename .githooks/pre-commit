#!/bin/sh
set -eu

if [ "${SKIP_PRECOMMIT:-}" = "1" ]; then
    exit 0
fi

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if command -v pre-commit >/dev/null 2>&1 && [ -f .pre-commit-config.yaml ]; then
    exec pre-commit run --hook-stage pre-commit
fi

sh scripts/pre-commit-checks.sh
